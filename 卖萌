            <div class="text-[clamp(2rem,6vw,3rem)] font-bold text-primary mb-6 heart-beat">
                <i class="fa fa-heart text-accent mr-3"></i>
                爱你宝贝
                <i class="fa fa-heart text-accent ml-3"></i>
            </div>
            
            <div class="text-lg text-gray-600 mb-8">
                <p>你真是太可爱了！</p>
            </div>
            
            <button id="restart-btn" class="bg-secondary hover:bg-primary text-white font-bold py-3 px-8 rounded-full shadow-lg btn-hover transition-all">
                <i class="fa fa-refresh mr-2"></i> 重新开始
            </button>
        </div>
    </div>

