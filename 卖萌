            <h1 class="text-[clamp(1.8rem,5vw,2.5rem)] font-bold text-primary mb-8 text-shadow">你是否愿意给我卖萌！</h1>
            
            <div id="question-container" class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <button id="yes-btn" class="btn-yes bg-primary hover:bg-accent text-white font-bold py-3 px-8 rounded-full shadow-lg btn-hover flex items-center justify-center">
                    <i class="fa fa-heart mr-2"></i> 是
                </button>
                <button id="no-btn" class="btn-no bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold py-3 px-8 rounded-full shadow-md btn-hover flex items-center justify-center">
                    <i class="fa fa-times mr-2"></i> 否
                </button>
            </div>
            
            <div id="doubts-container" class="mt-6 space-y-2"></div>
        </div>
    </div>
    
    <!-- 结果页面 -->
    <div id="result-container" class="hidden text-center fade-in">
